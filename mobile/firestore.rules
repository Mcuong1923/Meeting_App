rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions để kiểm tra quyền
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Cập nhật function phù hợp với enum UserRole
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }
    
    function isDirector() {
      return isAuthenticated() && getUserRole() == 'director';
    }
    
    function isManager() {
      return isAuthenticated() && getUserRole() == 'manager';
    }
    
    function isEmployee() {
      return isAuthenticated() && getUserRole() == 'employee';
    }
    
    function isGuest() {
      return isAuthenticated() && getUserRole() == 'guest';
    }
    
    function isPending() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'pending';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function sameDepartment(resourceData) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.departmentId == resourceData.data.departmentId;
    }
    
    function sameTeam(resourceData) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId == resourceData.data.teamId;
    }

    // Backward compatibility - Admin là quyền cao nhất
    function isSuperAdmin() {
      return isAdmin();
    }

    // Helper function: Kiểm tra user có phải là participant của meeting không
    // User là participant nếu: uid == creatorId HOẶC uid nằm trong participantIds
    function isMeetingParticipant(meetingId) {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid ||
        (get(/databases/$(database)/documents/meetings/$(meetingId)).data.participantIds != null &&
         get(/databases/$(database)/documents/meetings/$(meetingId)).data.participantIds.hasAny([request.auth.uid]))
      );
    }

    // ===== users =====
    match /users/{userId} {
      // READ
      allow read: if isOwner(userId) || isAdmin() || isDirector() || isManager();
      allow list: if isAuthenticated() && (isAdmin() || isDirector() || isManager());

      // CREATE: only self-registration
      allow create: if isOwner(userId) && isAuthenticated();

      // UPDATE
      allow update: if isAuthenticated() && (
        // 1. Owner: safe profile fields only (không thể tự thay đổi role/status hiện tại)
        // Cho phép Owner cập nhật các trường requested* để xin cấp quyền
        (isOwner(userId) &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'role', 'isRoleApproved', 'departmentId', 'teamId', 'teamName',
            'teamIds', 'teamNames', 'accountType', 'status', 'isActive'
          ])) ||

        // 2. Admin: full update EXCEPT chạm vào role/status của admin khác
        //    và KHÔNG tự thay đổi role của mình
        (isAdmin() &&
          request.auth.uid != userId &&
          !(resource.data.role == 'admin') &&
          request.resource.data.get('role', resource.data.role) != 'admin') ||

        // 3. Director (same dept):
        //    - KHÔNG thể chạm target đang là admin hoặc director khác
        //    - KHÔNG thể promote lên admin/director/manager
        //    - KHÔNG thể tự thay đổi role của mình
        (isDirector() &&
          !isAdmin() &&
          request.auth.uid != userId &&
          get(/databases/$(database)/documents/users/$(userId)).data.departmentId ==
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.departmentId &&
          // Current role của target phải là employee hoặc guest
          (resource.data.role == 'employee' || resource.data.role == 'guest') &&
          // New role chỉ được là employee hoặc guest
          (request.resource.data.get('role', resource.data.role) == 'employee' ||
           request.resource.data.get('role', resource.data.role) == 'guest')) ||

        // 4. Manager (same team): limited fields
        //    - KHÔNG thể chạm admin/director/manager khác
        //    - KHÔNG thể promote lên admin/director/manager
        //    - KHÔNG thể tự thay đổi role của mình
        (isManager() &&
          !isAdmin() && !isDirector() &&
          request.auth.uid != userId &&
          get(/databases/$(database)/documents/users/$(userId)).data.teamId ==
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'role', 'departmentId', 'accountType'
          ]))
      );

      // DELETE
      allow delete: if isAdmin() ||
        (isDirector() &&
         get(/databases/$(database)/documents/users/$(userId)).data.departmentId ==
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.departmentId);
    }

    // ===== meetings =====
    match /meetings/{meetingId} {
      // Helper function to check participant
      function isParticipant(resourceData) {
        return request.auth.uid in resourceData.data.participantIds;
      }
      
      function isMeetingCreator(resourceData) {
        return request.auth.uid == resourceData.data.creatorId;
      }
      
      // READ: Fix lộ toàn bộ meeting
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (isDirector() && (sameDepartment(resource) || isParticipant(resource) || isMeetingCreator(resource))) ||
        (isManager() && (sameTeam(resource) || isParticipant(resource) || isMeetingCreator(resource))) ||
        (isEmployee() && (isMeetingCreator(resource) || isParticipant(resource))) ||
        (isGuest() && isParticipant(resource))
      );
      
      // CREATE: Employee can only create pending & type=personal & must be participant
      allow create: if isAuthenticated() && (
        isAdmin() || isDirector() || isManager() ||
        (isEmployee() && 
         request.resource.data.status == 'pending' && 
         request.resource.data.type == 'personal' &&
         isOwner(request.resource.data.creatorId) &&
         isParticipant(request.resource))
      );
      
      // UPDATE: Tiered permission system
      allow update: if isAuthenticated() && (
        // 1. Admin: full update
        isAdmin() ||
        
        // 2. Director override approval
        (isDirector() && resource.data.approvalLevel == 'department' && sameDepartment(resource)) ||
        
        // 3. Manager override approval
        (isManager() && resource.data.approvalLevel == 'team' && sameTeam(resource)) ||
        
        // 4. Owner cancel
        (isMeetingCreator(resource) && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
         request.resource.data.status == 'cancelled') ||
        
        // 5. Owner update meeting details (not status/approval)
        (isMeetingCreator(resource) && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'approvalStatus', 'approvedBy']) &&
         resource.data.status == 'pending') ||
        
        // 6. ✅ Participant updates own attendanceStatus / hasConfirmed / respondedAt
        //    Only allowed to touch: participants array, participantIds, updatedAt
        (isAuthenticated() &&
         isParticipant(resource) &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['participants', 'participantIds', 'updatedAt']))
      );
      
      // DELETE: No hard delete recommended, but Admin can delete.
      allow delete: if isAdmin();
      
      // ===== comments (Bình luận cuộc họp) =====
      // Path: /meetings/{meetingId}/comments/{commentId}
      // Subcollection của meetings, check participant từ meeting document
      match /comments/{commentId} {
        // Đọc: User phải là creator hoặc participant của meeting
        // Check từ meeting document: uid == creatorId HOẶC uid nằm trong participantIds
        allow read: if isAuthenticated() && isMeetingParticipant(meetingId);
        
        // Tạo: User phải là participant VÀ phải set đúng authorId VÀ content không rỗng
        // isMeetingParticipant() sẽ get meeting document và check creatorId/participantIds
        allow create: if isAuthenticated() && 
          isMeetingParticipant(meetingId) &&
          request.resource.data.authorId == request.auth.uid &&
          request.resource.data.meetingId == meetingId &&
          request.resource.data.content != null &&
          request.resource.data.content is string &&
          request.resource.data.content.size() > 0 &&
          request.resource.data.createdAt != null &&
          request.resource.data.updatedAt != null;
        
        // Cập nhật: Chỉ author của comment có thể sửa
        allow update: if isAuthenticated() && 
          isOwner(resource.data.authorId) &&
          request.resource.data.authorId == resource.data.authorId &&
          request.resource.data.meetingId == resource.data.meetingId;
        
        // Xóa: Chỉ author của comment có thể xóa
        allow delete: if isAuthenticated() && 
          isOwner(resource.data.authorId);
      }
    }

    // ===== rooms =====
    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isAdmin();
      allow update: if isAuthenticated() && isAdmin();
      allow delete: if isAuthenticated() && isAdmin();
    }

    // ===== departments =====
    match /departments/{departmentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        (isDirector() || isAdmin());
    }

    // ===== teams =====
    match /teams/{teamId} {
      // Read: any authenticated user can read teams (needed for role selection dropdown)
      // Including pending users who need to select their team
      allow read: if isAuthenticated();
      
      // Create/Update: admin full access, director only for their department
      allow create, update: if isAuthenticated() && (
        isAdmin() ||
        (isDirector() && request.resource.data.departmentId == 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.departmentId)
      );
      
      // Delete: only admin
      allow delete: if isAdmin();
    }


    // ===== notifications =====
    match /notifications/{notificationId} {
      // Only privileged roles can broadcast / create notifications
      allow create: if isAdmin() ||
        (isDirector() && sameDepartment(request.resource)) ||
        (isManager() && sameTeam(request.resource));

      // READ:
      // - Admins can read all
      // - Creator can always read their own notifications
      // - Normal users can read notifications targeted to them via:
      //   - recipients array (canonical)
      //   - legacy userId field (backward compatibility)
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource.data.createdBy == request.auth.uid ||
        (resource.data.recipients != null &&
          request.auth.uid in resource.data.recipients) ||
        // Legacy one-to-one notifications that still use userId
        (resource.data.userId != null &&
          resource.data.userId == request.auth.uid)
      );
      
      allow update, delete: if isAuthenticated() && (
        isAdmin() ||
        resource.data.createdBy == request.auth.uid
      );
    }

    // ===== analytics_events =====
    // Centralized analytics event stream.
    // - Any authenticated user can WRITE analytics events for tracking.
    // - Only admins can READ/UPDATE/DELETE analytics events.
    match /analytics_events/{eventId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // ===== reports =====
    match /reports/{reportId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isAdmin();
      allow delete: if isAdmin();
    }

    // ===== maintenance_records =====
    match /maintenance_records/{recordId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isAdmin();
      allow delete: if isAdmin();
    }

    // ===== room_bookings =====
    match /room_bookings/{bookingId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        isDirector() || 
        isManager() || 
        isOwner(resource.data.createdBy) || 
        request.auth.uid in resource.data.participantIds
      );
      
      // Booking restrictions: Guest and Employee MUST have an approved meeting to book
      allow create: if isAuthenticated() && (
        isAdmin() || isDirector() || isManager() ||
        ((isEmployee() || isGuest()) && 
         request.resource.data.meetingId != null &&
         get(/databases/$(database)/documents/meetings/$(request.resource.data.meetingId)).data.status == 'approved' &&
         (isOwner(request.resource.data.createdBy) || request.auth.uid in get(/databases/$(database)/documents/meetings/$(request.resource.data.meetingId)).data.participantIds))
      );
      
      allow update: if isAuthenticated() && 
        (
          isAdmin() || isDirector() || isManager() ||
          // Owner cancel
          (isOwner(resource.data.createdBy) && 
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
           request.resource.data.status == 'cancelled')
        );
        
      allow delete: if isAdmin();
    }

    // ===== user_booking_stats =====
    match /user_booking_stats/{userId} {
      allow read: if isAuthenticated() && 
        (isOwner(userId) || isAdmin() || isManager());
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ===== decisions =====
    match /decisions/{decisionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
        (
          isOwner(resource.data.createdBy) ||
          isManager() || isDirector() || isAdmin()
        );
      allow delete: if isAuthenticated() && 
        (
          isOwner(resource.data.createdBy) ||
          isDirector() || isAdmin()
        );
    }

    // ===== meeting_minutes =====
    match /meeting_minutes/{minutesId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
        (
          isOwner(resource.data.createdBy) ||
          isManager() || isDirector() || isAdmin()
        );
      allow delete: if isAuthenticated() && 
        (
          isOwner(resource.data.createdBy) ||
          isDirector() || isAdmin()
        );
    }

    // ===== tasks =====
    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (
          isOwner(resource.data.createdBy) ||
          isOwner(resource.data.assigneeId) ||
          isManager() || isDirector() || isAdmin()
        );
      allow delete: if isAuthenticated() &&
        (
          isOwner(resource.data.createdBy) ||
          isManager() || isDirector() || isAdmin()
        );
    }

    // ===== files (tài liệu cuộc họp) =====
    match /files/{fileId} {
      // Đọc: bất kỳ user đã đăng nhập đều xem được file (theo meetingId đã filter trên app)
      allow read: if isAuthenticated();

      // Tạo: user đăng nhập có thể upload file
      allow create: if isAuthenticated();

      // Cập nhật: chỉ uploader hoặc admin/manager/director
      allow update: if isAuthenticated() &&
        (
          isOwner(resource.data.uploaderId) ||
          isManager() || isDirector() || isAdmin()
        );

      // Xóa: chỉ uploader hoặc admin/director
      allow delete: if isAuthenticated() &&
        (
          isOwner(resource.data.uploaderId) ||
          isDirector() || isAdmin()
        );
    }

    // Rules mặc định: Từ chối tất cả các truy cập khác
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
