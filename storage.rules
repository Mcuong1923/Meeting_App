rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Files của cuộc họp: meetings/{meetingId}/files/{fileName}
    match /meetings/{meetingId}/files/{fileName} {
      // Đọc: user đã đăng nhập
      allow read: if request.auth != null;
      // Upload: user đã đăng nhập, kích thước <= 50MB
      allow create: if request.auth != null
                    && request.resource.size <= 50 * 1024 * 1024;
      // Xóa: user đã đăng nhập (uploader check ở Firestore layer)
      allow delete: if request.auth != null;
    }

    // Files trong folder: folders/{folderId}/files/{fileName}
    match /folders/{folderId}/files/{fileName} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.size <= 50 * 1024 * 1024;
      allow delete: if request.auth != null;
    }

    // Files chung: files/{fileName}
    match /files/{fileName} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.size <= 50 * 1024 * 1024;
      allow delete: if request.auth != null;
    }

    // Avatars
    match /avatars/{fileName} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                             && request.resource.size <= 5 * 1024 * 1024
                             && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }
  }
}
